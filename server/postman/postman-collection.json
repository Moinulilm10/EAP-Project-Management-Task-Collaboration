    {
      "name": "Project Management",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.environment.get('accessToken') || pm.variables.get('accessToken');",
                  "if (token) { pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token }); }",
                  "pm.request.headers.add({ key: 'X-Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "const jsonData = pm.response.json();",
                  "pm.test('Project schema is valid', function () { pm.expect(jsonData.project).to.have.property('id'); pm.expect(jsonData.project).to.have.property('name'); pm.expect(jsonData.project).to.have.property('status'); });",
                  "if (jsonData.project && jsonData.project.id) { pm.environment.set('projectId', jsonData.project.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Project\",\n  \"description\": \"A new project description.\",\n  \"deadline\": \"2026-12-31T23:59:59.000Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["projects"]
            }
          }
        },
        {
          "name": "Read All Projects",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.environment.get('accessToken') || pm.variables.get('accessToken');",
                  "if (token) { pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token }); }"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const jsonData = pm.response.json();",
                  "pm.test('Response contains project list', function () { pm.expect(jsonData.projects).to.be.an('array'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects?status={{projectStatus}}&search={{projectSearch}}&page={{page}}&limit={{limit}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects"],
              "query": [
                {
                  "key": "status",
                  "value": "{{projectStatus}}"
                },
                {
                  "key": "search",
                  "value": "{{projectSearch}}"
                },
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                }
              ]
            }
          }
        },
        {
          "name": "Update Project",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.environment.get('accessToken') || pm.variables.get('accessToken');",
                  "if (token) { pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token }); }",
                  "pm.request.headers.add({ key: 'X-Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ],
                "type": "text/javascript"
