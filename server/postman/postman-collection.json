              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const jsonData = pm.response.json();",
                  "pm.test('Project update returns object', function () { pm.expect(jsonData.project).to.have.property('id'); pm.expect(jsonData.project.name).to.eql('Updated Project Name'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project Name\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
